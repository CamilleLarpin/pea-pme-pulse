dapter_response": {}, "message": null, "failures": null, "unique_id": "test.pea_pme_pulse.source_not_null_bronze_yfinance_ohlcv_Close.fe9d680917", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect Close\nfrom `bootcamp-project-pea-pme`.`bronze`.`yfinance_ohlcv`\nwhere Close is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-02T23:39:40.976039Z", "completed_at": "2026-04-02T23:39:41.048342Z"}, {"name": "execute", "started_at": "2026-04-02T23:39:41.058551Z", "completed_at": "2026-04-02T23:39:41.058589Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.11444306373596191, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.pea_pme_pulse.rss_articles", "compiled": true, "compiled_code": "-- Silver: unified RSS articles from all sources\n-- Incremental merge on row_id \u2014 only processes new Bronze rows each run.\n-- row_id: surrogate key on (lower(title), isin) \u2014 stable dedup key across sources\n-- published_at: parsed from RFC 2822 string (e.g. \"Thu, 02 Apr 2026 15:30:00 GMT\")\n\n\n\nwith yahoo as (\n    select\n        to_hex(md5(concat(lower(title), '|', isin))) as row_id,\n        title,\n        link,\n        summary,\n        matched_name,\n        cast(match_score as float64) as match_score,\n        isin,\n        ticker_bourso,\n        fetched_at,\n        'yahoo_rss' as source,\n        safe.parse_timestamp('%a, %d %b %Y %H:%M:%S %Z', published) as published_at\n    from `bootcamp-project-pea-pme`.`bronze`.`yahoo_rss`\n    where isin is not null\n    \n    and fetched_at > (select max(fetched_at) from `bootcamp-project-pea-pme`.`silver`.`rss_articles`)\n    \n),\n\ngoogle_news as (\n    select\n        to_hex(md5(concat(lower(title), '|', isin))) as row_id,\n        title,\n        link,\n        summary,\n        matched_name,\n        cast(match_score as float64) as match_score,\n        isin,\n        ticker_bourso,\n        fetched_at,\n        'google_news_rss' as source,\n        safe.parse_timestamp('%a, %d %b %Y %H:%M:%S %Z', published) as published_at\n    from `bootcamp-project-pea-pme`.`bronze`.`google_news_rss`\n    where isin is not null\n    \n    and fetched_at > (select max(fetched_at) from `bootcamp-project-pea-pme`.`silver`.`rss_articles`)\n    \n),\n\nunioned as (\n    select * from yahoo\n    union all\n    select * from google_news\n),\n\ndeduped as (\n    select *\n    from unioned\n    qualify row_number() over (\n        partition by row_id\n        order by fetched_at desc\n    ) = 1\n)\n\nselect * from deduped", "relation_name": "`bootcamp-project-pea-pme`.`silver`.`rss_articles`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-02T23:39:41.098787Z", "completed_at": "2026-04-02T23:39:41.135427Z"}, {"name": "execute", "started_at": "2026-04-02T23:39:41.138883Z", "completed_at": "2026-04-02T23:39:41.138905Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.07045888900756836, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pea_pme_pulse.not_null_rss_articles_row_id.aa0a7d1131", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect row_id\nfrom `bootcamp-project-pea-pme`.`silver`.`rss_articles`\nwhere row_id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-02T23:39:41.092779Z", "completed_at": "2026-04-02T23:39:41.136606Z"}, {"name": "execute", "started_at": "2026-04-02T23:39:41.140448Z", "completed_at": "2026-04-02T23:39:41.140485Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.0737922191619873, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.pea_pme_pulse.not_null_rss_articles_isin.77f5f6c43e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect isin\nfrom `bootcamp-project-pea-pme`.`silver`.`rss_articles`\nwhere isin