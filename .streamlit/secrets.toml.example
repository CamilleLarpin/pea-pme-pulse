# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml — it is in .gitignore.
#
# On Streamlit Community Cloud: paste the contents of your GCP service account
# JSON under [gcp_service_account] via the "Secrets" settings panel.

[gcp_service_account]
type = "service_account"
project_id = "bootcamp-project-pea-pme"
private_key_id = "YOUR_PRIVATE_KEY_ID"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "YOUR_SERVICE_ACCOUNT@bootcamp-project-pea-pme.iam.gserviceaccount.com"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "YOUR_CERT_URL"
