# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml — it is in .gitignore.
#
# URL de l'API FastAPI — en local ou sur la VM GCP.
# Sur Streamlit Community Cloud : renseigner dans le panneau "Secrets".
api_base_url = "http://localhost:8000"  # VM : http://35.241.252.5:8000
api_key = "your_api_key_here"           # same value as API_KEY on the VM
